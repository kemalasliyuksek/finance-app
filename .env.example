# ==============================================================================
# Finance App - Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# All variables marked REQUIRED must be set before the app will start.
# Variables marked OPTIONAL have working defaults; leave them empty to use the default.
# ==============================================================================


# ------------------------------------------------------------------------------
# Application Mode
# ------------------------------------------------------------------------------
# APP_MODE: How the bot interacts with the market
#   - sandbox  : Real Binance market data, simulated orders, virtual wallet (RECOMMENDED FOR FIRST RUN)
#   - testnet  : Binance testnet (testnet.binance.vision) — needs testnet API keys
#   - live     : Real money on Binance mainnet — needs production API keys
#   - backtest : Historical data only, no live trading
APP_MODE=sandbox

# TRADING_MODE: How signals are approved
#   - semi_auto : Signals require manual approval (Telegram or Dashboard)
#   - full_auto : Signals are auto-approved and executed
TRADING_MODE=semi_auto

LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# Binance API Credentials
# ------------------------------------------------------------------------------
# Get them from https://www.binance.com/en/my/settings/api-management
# For LIVE mode (real money) — REQUIRED if APP_MODE=live
BINANCE_API_KEY=
BINANCE_API_SECRET=

# For TESTNET mode — REQUIRED if APP_MODE=testnet
# Get them from https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=


# ------------------------------------------------------------------------------
# Database & Cache (REQUIRED)
# ------------------------------------------------------------------------------
# Pick a strong password. Used by both the bot and the postgres container.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Connection strings consumed by the application.
# When using docker compose, the hosts `trading-postgres` and `trading-redis`
# are resolved automatically. For local dev outside Docker, use `localhost`.
DATABASE_URL=postgresql+asyncpg://trading_bot:change-me-to-a-strong-password@trading-postgres:5432/trading_bot?ssl=disable
REDIS_URL=redis://trading-redis:6379/0


# ------------------------------------------------------------------------------
# JWT Authentication (REQUIRED)
# ------------------------------------------------------------------------------
# Used to sign dashboard login tokens. MUST be at least 32 characters in live mode.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-secret-of-at-least-32-characters


# ------------------------------------------------------------------------------
# Dashboard / CORS (REQUIRED for dashboard access)
# ------------------------------------------------------------------------------
# Comma-free JSON array of allowed origins. Add your public dashboard URL here.
# Examples:
#   Local dev   : ["http://localhost:3000","http://localhost:3003"]
#   Production  : ["https://trading.example.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3003"]

# URLs the dashboard uses to reach the backend (build-time for Next.js).
# Same host the dashboard is served from, plus /api/v1 and /ws paths.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws


# ------------------------------------------------------------------------------
# Telegram Bot (OPTIONAL — leave empty to disable Telegram notifications)
# ------------------------------------------------------------------------------
# 1. Create a bot with @BotFather on Telegram, copy the HTTP API token.
# 2. Send /start to your bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ------------------------------------------------------------------------------
# Error Tracking — Sentry / GlitchTip (OPTIONAL)
# ------------------------------------------------------------------------------
# Compatible with both sentry.io and self-hosted GlitchTip.
SENTRY_DSN=


# ------------------------------------------------------------------------------
# Trading Pairs & Intervals
# ------------------------------------------------------------------------------
# Initial watchlist. The screener will dynamically add/remove pairs around this set.
# JSON array, no spaces.
TRADING_PAIRS=["BTCUSDT","ETHUSDT"]
CANDLE_INTERVALS=["15m","1h"]


# ------------------------------------------------------------------------------
# Risk Limits (overridable from the dashboard at runtime)
# ------------------------------------------------------------------------------
# All percentages are decimals: 0.02 = 2 %.
RISK_PER_TRADE_PCT=0.02
MAX_CONCURRENT_POSITIONS=2
MAX_ASSET_ALLOCATION_PCT=0.40
DAILY_LOSS_LIMIT_PCT=0.05
MIN_BALANCE_USDT=50.0


# ------------------------------------------------------------------------------
# Screener (dynamic market scanner)
# ------------------------------------------------------------------------------
SCREENER_ENABLED=true
SCREENER_INTERVAL_SECONDS=300
SCREENER_VOLUME_TOP_N=5


# ------------------------------------------------------------------------------
# Docker Image (OPTIONAL — only needed if you publish your own images)
# ------------------------------------------------------------------------------
# When deploying via a registry (GHCR, Docker Hub, …), set these so docker-compose
# pulls your image instead of building locally. Leave defaults to build from source.
#
# Example for a fork:
#   DOCKER_REGISTRY=ghcr.io
#   DOCKER_OWNER=your-github-username
#   DOCKER_IMAGE_TAG=latest
DOCKER_REGISTRY=ghcr.io
DOCKER_OWNER=your-github-username
DOCKER_IMAGE_TAG=latest


# ------------------------------------------------------------------------------
# Data Directory (host paths used for Docker bind mounts)
# ------------------------------------------------------------------------------
# Where postgres data, redis data, and bot logs live on the host. Relative paths
# are resolved against the docker-compose.yml location.
DATA_DIR=./data
